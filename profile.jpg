/* Reset */
* {
    margin: 0;
    padding: 0;
    box-sizing: border-box;
}

body {
    font-family: "Poppins", sans-serif;
    background: #f5f7fa;
    color: #1f2937;
}

/* Header */
header {
    background: #0f172a;
    position: sticky;
    top: 0;
    z-index: 1000;
}

.navbar {
    width: 90%;
    max-width: 1200px;
    margin: auto;

    display: flex;
    justify-content: space-between;
    align-items: center;

    padding: 18px 0;
}

.logo h2 {
    color: white;
}

.nav-links {
    list-style: none;
    display: flex;
    gap: 20px;
}

.nav-links a {
    text-decoration: none;
    color: white;
    transition: .3s;
}

.nav-links a:hover,
.nav-links a.active {
    color: #3b82f6;
}

/* Hero */

.hero {
    width: 90%;
    max-width: 1200px;
    margin: auto;

    min-height: 90vh;

    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 50px;
}

.hero-text {
    flex: 1;
}

.hero-text h1 {
    font-size: 48px;
    margin-bottom: 15px;
}

.hero-text span {
    color: #2563eb;
}

.hero-text h3 {
    margin-bottom: 20px;
    color: #475569;
}

.hero-text p {
    line-height: 1.8;
    margin-bottom: 30px;
}

.btn {
    display: inline-block;
    padding: 12px 30px;
    background: #2563eb;
    color: white;
    text-decoration: none;
    border-radius: 8px;
    transition: .3s;
}

.btn:hover {
    background: #1d4ed8;
}

.hero-image {
    flex: 1;
    text-align: center;
}

.hero-image img {
    width: 350px;
    border-radius: 50%;
    box-shadow: 0 15px 30px rgba(0,0,0,.15);
}

/* Footer */

footer {
    background: #0f172a;
    color: white;
    text-align: center;
    padding: 25px;
}

.social-links {
    margin-top: 10px;
}

.social-links a {
    color: white;
    text-decoration: none;
    margin: 0 10px;
}

.social-links a:hover {
    color: #3b82f6;
}

/* Responsive */

@media (max-width: 900px) {

    .navbar {
        flex-direction: column;
    }

    .nav-links {
        flex-wrap: wrap;
        justify-content: center;
        margin-top: 15px;
    }

    .hero {
        flex-direction: column-reverse;
        text-align: center;
        padding: 60px 0;
    }

    .hero-text h1 {
        font-size: 36px;
    }

    .hero-image img {
        width: 250px;
    }

}
/* ===========================
   ABOUT PAGE
=========================== */

.page-header{
    background:#2563eb;
    color:white;
    text-align:center;
    padding:70px 20px;
}

.about-container{
    width:90%;
    max-width:1200px;
    margin:60px auto;

    display:flex;
    gap:60px;
    align-items:center;
}

.about-image{
    flex:1;
    text-align:center;
}

.about-image img{
    width:320px;
    border-radius:15px;
    box-shadow:0 10px 25px rgba(0,0,0,.15);
}

.about-content{
    flex:2;
}

.about-content h2,
.about-content h3{
    color:#2563eb;
    margin-bottom:15px;
}

.about-content p{
    margin-bottom:20px;
    line-height:1.8;
}

.about-content ul{
    margin-left:20px;
    margin-bottom:20px;
}

.about-content li{
    margin-bottom:10px;
}

@media(max-width:900px){

.about-container{
    flex-direction:column;
    text-align:center;
}

.about-content ul{
    list-style-position:inside;
    margin-left:0;
}

}
/* ===========================
   SKILLS PAGE
=========================== */

.skills-container{
    width:90%;
    max-width:1200px;
    margin:60px auto;

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(260px,1fr));
    gap:25px;
}

.skill-card{
    background:#fff;
    padding:25px;
    border-radius:12px;
    box-shadow:0 10px 20px rgba(0,0,0,.08);
    transition:.3s;
}

.skill-card:hover{
    transform:translateY(-8px);
}

.skill-card h3{
    color:#2563eb;
    margin-bottom:15px;
}

.skill-card p{
    line-height:1.7;
}

.progress-section{
    width:90%;
    max-width:800px;
    margin:70px auto;
}

.progress-section h2{
    text-align:center;
    margin-bottom:35px;
}

.progress-item{
    margin-bottom:25px;
}

.progress-item span{
    display:block;
    margin-bottom:8px;
    font-weight:600;
}

.progress{
    width:100%;
    background:#ddd;
    border-radius:25px;
    overflow:hidden;
}

.progress-bar{
    background:#2563eb;
    color:#fff;
    padding:10px;
    text-align:right;
}

.html{
    width:90%;
}

.css{
    width:85%;
}

.js{
    width:65%;
}

.git{
    width:80%;
}/* ===========================
   PROJECTS PAGE
=========================== */

.projects-container{

    width:90%;
    max-width:1200px;

    margin:60px auto;

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(320px,1fr));

    gap:30px;

}

.project-card{

    background:#fff;

    border-radius:15px;

    overflow:hidden;

    box-shadow:0 10px 25px rgba(0,0,0,.1);

    transition:.3s;

}

.project-card:hover{

    transform:translateY(-10px);

}

.project-card img{

    width:100%;

    height:220px;

    object-fit:cover;

}

.project-card h3{

    margin:20px;

    color:#2563eb;

}

.project-card p{

    margin:0 20px 20px;

    line-height:1.7;

}

.project-card .btn{

    display:inline-block;

    margin:0 20px 25px;

}/* ===========================
   SERVICES PAGE
=========================== */

.services-container{
    width:90%;
    max-width:1200px;
    margin:60px auto;

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr));
    gap:30px;
}

.service-card{

    background:#fff;

    padding:30px;

    border-radius:15px;

    box-shadow:0 10px 20px rgba(0,0,0,.08);

    transition:.3s;
}

.service-card:hover{

    transform:translateY(-10px);

}

.service-card h2{

    color:#2563eb;

    margin-bottom:20px;

    font-size:24px;

}

.service-card p{

    line-height:1.8;

}

.cta{

    background:#2563eb;

    color:white;

    text-align:center;

    padding:70px 20px;

}

.cta h2{

    font-size:36px;

    margin-bottom:15px;

}

.cta p{

    margin-bottom:30px;

    font-size:18px;

}

.cta .btn{

    background:white;

    color:#2563eb;

    font-weight:bold;

}

.cta .btn:hover{

    background:#f3f4f6;

}
/* ===========================
   GALLERY PAGE
=========================== */

.gallery-container{
    width:90%;
    max-width:1200px;
    margin:60px auto;

    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(280px,1fr));
    gap:25px;
}

.gallery-item{
    overflow:hidden;
    border-radius:15px;
    box-shadow:0 10px 20px rgba(0,0,0,.1);
}

.gallery-item img{
    width:100%;
    height:250px;
    object-fit:cover;
    display:block;
    transition:0.4s;
}

.gallery-item:hover img{
    transform:scale(1.08);
}/* ===========================
   RESUME PAGE
=========================== */

.resume-container{
    width:90%;
    max-width:1000px;
    margin:60px auto;
}

.resume-section{
    background:#fff;
    margin-bottom:25px;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 20px rgba(0,0,0,.08);
}

.resume-section h2{
    color:#2563eb;
    margin-bottom:15px;
}

.resume-section p,
.resume-section li{
    line-height:1.8;
}

.resume-section ul{
    margin-left:20px;
}

.download-cv{
    text-align:center;
    margin-top:40px;
}
/* ===========================
   BLOG PAGE
=========================== */

.blog-container{
    width:90%;
    max-width:1000px;
    margin:60px auto;
}

.blog-card{
    background:#fff;
    margin-bottom:30px;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 20px rgba(0,0,0,.08);
}

.blog-card h2{
    color:#2563eb;
    margin-bottom:10px;
}

.blog-date{
    color:#64748b;
    font-size:14px;
    margin-bottom:20px;
}

.blog-card p{
    line-height:1.8;
    margin-bottom:20px;
}
/* ===========================
   CONTACT PAGE
=========================== */

.contact-container{
    width:90%;
    max-width:1200px;
    margin:60px auto;

    display:grid;
    grid-template-columns:1fr 1fr;
    gap:40px;
}

.contact-info,
.contact-form{
    background:#fff;
    padding:30px;
    border-radius:15px;
    box-shadow:0 10px 20px rgba(0,0,0,.08);
}

.contact-info h2{
    color:#2563eb;
    margin-bottom:20px;
}

.contact-info p{
    margin-bottom:15px;
    line-height:1.8;
}

.contact-form form{
    display:flex;
    flex-direction:column;
}

.contact-form input,
.contact-form textarea{
    padding:15px;
    margin-bottom:20px;
    border:1px solid #ccc;
    border-radius:8px;
    font-family:"Poppins",sans-serif;
}

.contact-form textarea{
    resize:vertical;
}

@media(max-width:768px){

.contact-container{
    grid-template-columns:1fr;
}

}
/* ===========================
   LEARNING JOURNEY
=========================== */

.learning-container{

    width:90%;
    max-width:1200px;

    margin:60px auto;

    display:grid;

    grid-template-columns:2fr 1fr;

    gap:40px;

}

.journey-text{

    background:#fff;

    padding:30px;

    border-radius:15px;

    box-shadow:0 10px 20px rgba(0,0,0,.08);

}

.journey-text h2{

    color:#2563eb;

    margin-bottom:15px;

}

.journey-text p{

    line-height:1.8;

    margin-bottom:20px;

}

.certificate{

    background:#fff;

    padding:20px;

    text-align:center;

    border-radius:15px;

    box-shadow:0 10px 20px rgba(0,0,0,.08);

}

.certificate img{

    width:100%;

    border-radius:10px;

}

.certificate p{

    margin-top:15px;

    font-weight:bold;

}

.future-goals{

    width:90%;

    max-width:1200px;

    margin:60px auto;

}

.future-goals h2{

    text-align:center;

    margin-bottom:40px;

}

.goals{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));

    gap:25px;

}

.goal-card{

    background:#fff;

    padding:30px;

    text-align:center;

    border-radius:15px;

    box-shadow:0 10px 20px rgba(0,0,0,.08);

}

.goal-card h3{

    color:#2563eb;

    margin-bottom:15px;

}

@media(max-width:900px){

.learning-container{

grid-template-columns:1fr;

}

}
.btn{
    transition:0.3s ease;
}

.btn:hover{
    transform:translateY(-3px);
    box-shadow:0 10px 20px rgba(37,99,235,.3);
}
img{
    max-width:100%;
    display:block;
}
.back-top{
    position:fixed;
    right:20px;
    bottom:20px;
    width:45px;
    height:45px;
    background:#2563eb;
    color:#fff;
    text-decoration:none;
    border-radius:50%;
    display:flex;
    justify-content:center;
    align-items:center;
    font-size:22px;
}